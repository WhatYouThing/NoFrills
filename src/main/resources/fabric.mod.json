{
  "schemaVersion": 1,
  "id": "nofrills",
  "version": "${version}",
  "name": "NoFrills",
  "description": "It's in the name. Simple and effective Hypixel Skyblock mod for modern versions of Minecraft.",
  "authors": [
    "WhatYouThing"
  ],
  "contact": {
    "sources": "https://github.com/WhatYouThing/NoFrills"
  },
  "license": "GPL-3.0",
  "icon": "assets/nofrills/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "nofrills.Main"
    ]
  },
  "mixins": [
    "nofrills.mixins.json"
  ],
  "accessWidener" : "nofrills.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "owo-lib": "*",
    "minecraft": ">=${minecraft_version}",
    "java": ">=25"
  }
}